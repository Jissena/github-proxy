# Copy file ini menjadi .env.local untuk development
# Di Vercel, set variabel ini di: Settings → Environment Variables

# Token rahasia untuk akses file (ganti dengan token kuat)
SECRET_TOKEN=token-rahasia-kamu

# Base URL raw GitHub kamu
# Format: https://raw.githubusercontent.com/USERNAME/REPO/BRANCH
GITHUB_RAW_BASE=https://raw.githubusercontent.com/USERNAME/REPO/main
